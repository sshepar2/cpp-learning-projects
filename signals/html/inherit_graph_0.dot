digraph "Graphical Class Hierarchy"
{
 // LATEX_PDF_SIZE
  bgcolor="transparent";
  edge [fontname=Helvetica,fontsize=10,labelfontname=Helvetica,labelfontsize=10];
  node [fontname=Helvetica,fontsize=10,shape=box,height=0.2,width=0.4];
  rankdir="LR";
  Node0 [id="Node000000",label="Signal",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$classSignal.html",tooltip="Abstract base class representing a digitally sampled signal."];
  Node0 -> Node1 [id="edge1_Node000000_Node000001",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node1 [id="Node000001",label="BandPassFilter",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$classBandPassFilter.html",tooltip="Band-pass filter that isolates a frequency range using the DFT."];
  Node0 -> Node2 [id="edge2_Node000000_Node000002",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node2 [id="Node000002",label="MovingAverageFilter",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$classMovingAverageFilter.html",tooltip="Low-pass filter that smooths a signal using a sliding window average."];
  Node0 -> Node3 [id="edge3_Node000000_Node000003",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node3 [id="Node000003",label="NoisySignal",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$classNoisySignal.html",tooltip="Represents a raw unprocessed signal with no filtering applied."];
}
